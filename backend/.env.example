REMOTE_MONITORING_MAX_IMAGE_SIZE_MB=15
REMOTE_MONITORING_MAX_ORTHOMOSAIC_SIZE_MB=250
REMOTE_MONITORING_MAX_IMAGES_PER_SURVEY=50
