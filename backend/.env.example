AI_REQUEST_TIMEOUT_MS=30000
AI_DAILY_REQUEST_LIMIT=25
SATELLITE_PROVIDER=demo
SATELLITE_API_KEY=
SATELLITE_API_SECRET=
SATELLITE_API_BASE_URL=
SATELLITE_REQUEST_TIMEOUT_MS=30000
SATELLITE_CACHE_TTL_MINUTES=360
